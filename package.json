{
	"name": "my-snow-monkey-boilerplate",
	"private": true,
	"type": "module",
	"scripts": {
		"wp-env": "wp-env",
		"postcss": "postcss src/styles/style.css --dir dist",
		"build": "run-p build:*",
		"build:styles": "npm run postcss",
		"watch": "run-p watch:*",
		"watch:styles": "npm run postcss -- -w",
		"watch:server": "browser-sync start --proxy \"localhost:8888\" --files .",
		"lint": "run-p lint:*",
		"lint:stylelint": "stylelint '**/*.css'",
		"lint:prettier": "prettier . --check --ignore-unknown",
		"fix": "run-s fix:{stylelint,prettier}",
		"fix:stylelint": "npm run lint:stylelint -- --fix",
		"fix:prettier": "npm run lint:prettier -- --write"
	},
	"devDependencies": {
		"@wordpress/browserslist-config": "6.48.0",
		"@wordpress/env": "11.8.0",
		"@wordpress/prettier-config": "4.48.0",
		"@wordpress/stylelint-config": "23.40.0",
		"autoprefixer": "10.5.0",
		"browser-sync": "3.0.4",
		"cssnano": "8.0.2",
		"lefthook": "2.1.9",
		"npm-run-all2": "9.0.2",
		"postcss": "8.5.15",
		"postcss-cli": "11.0.1",
		"postcss-import": "16.1.1",
		"postcss-nested": "7.0.2",
		"postcss-preset-env": "11.3.1",
		"stylelint": "16.26.1",
		"stylelint-config-recess-order": "7.7.0"
	},
	"volta": {
		"node": "24.17.0"
	}
}
